# EduLibya Learning Hub - Environment Variables Template
# Copy this file to .env and fill in the values

# Database Connection (Neon/Postgres)
# Get this from https://console.neon.tech/
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Media Storage (Cloudinary)
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Security
# Run 'openssl rand -base64 32' to generate secure secrets
JWT_SECRET=change_me_to_a_random_secret
SESSION_SECRET=change_me_to_a_random_secret

# Email (Brevo / SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user
SMTP_PASS=your_brevo_smtp_password
SMTP_FROM="Your App Name" <noreply@yourdomain.com>

# LiveKit Cloud — Free Tier
# 1. Go to https://cloud.livekit.io → select your project → Settings → Keys
# 2. Generate a new API key and copy the key + secret
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud
